{
  "general": {
    "architecture": "any",
    "conflicts": [
      "letsencrypt"
    ],
    "depends": [
      "python3(>=3.10.0)"
    ],
    "email": "julien@cappysan.dev",
    "firmware": "5.0.0",
    "maintainer": "Cappysan",
    "name": "Certbot",
    "package": "cappysan-certbot",
    "version": "5.2.2-r30",
    "developer": "Cappysan",
    "website": "https://gitlab.com/cappysan/asustor/certbot"
  },
  "adm-desktop": {
    "app": {
      "type": "internal",
      "js": [
        "certbot.js"
      ],
      "css": [
        "certbot.css"
      ],
      "module": "AS.ARC.apps.certbot.main",
      "langTag": "CERTBOT"
    },
    "privilege": {
      "accessible": "administrators",
      "customizable": false
    }
  },
  "register": {
    "share-folder": [
      {
        "name": "Configuration",
        "description": "Application configuration"
      }
    ],
    "boot-priority": {
      "x-comment": "docker-ce start order is 65",
      "start-order": 50,
      "stop-order": 30
    }
  }
}
