#!/usr/bin/env sh
# SPDX-License-Identifier: MIT
#
. /usr/local/AppCentral/cappysan-certbot/.env.install
cd ${APKG_CFG_DIR:-/nonexistent} || exit 1
. ${APKG_PKG_DIR}/env

# We need openssl
export PATH=$PATH:/usr/builtin/bin/

# If issuer is Asustor, then our certificates are not installed
if test "x${RENEWED_LINEAGE}" == "x"; then
  logger "[${WHAT}] Skipping 01-lighthttpd hook, RENEWED_LINEAGE is not set"
  exit 1
elif openssl x509 -noout -text -in  /usr/builtin/etc/certificate/ssl.crt | grep Issuer | grep -q Asustor; then
  logger "[${WHAT}] Skipping 01-lighthttpd hook, certificate is from Asustor, not restarting ${WHAT}"
  exit 1
elif test ! -f "${RENEWED_LINEAGE}"/cert.pem; then
  logger "[${WHAT}] Skipping 01-lighthttpd hook, Certificates not found in ${RENEWED_LINEAGE}, not restarting lighttpd"
  exit 1
elif openssl x509 -noout -text -in "${RENEWED_LINEAGE}"/cert.pem | grep Issuer | grep -q "Let's Encrypt"; then
  true
else
  logger "[${WHAT}] Skipping 01-lighthttpd hook, certificate is neither from Asustor nor Let's Encrypt, not restarting lighttpd"
  exit 1
fi

if test -f /etc/init.d/S41lighttpd; then
  logger "[${WHAT}] Restarting lighttpd..."
  /etc/init.d/S41lighttpd restart
fi
exit 0
